[color]
	ui = true
[core]
	excludesfile = /Users/rwjpeelen/.gitignore_global
	autocrlf = false
	ignorecase = false
	sparseCheckout = false
[user]
	name = Roland Peelen
	email = rolandpeelen@gmail.com
	signingkey = B1EE26699E316CFA
[push]
	default = upstream
	autoSetupRemote = true
[commit]
	template = ~/.stdCommitMessage
	gpgsign = true
[init]
	defaultBranch = master
[pull]
	ff = only
[merge]
	conflictstyle = diff3
[diff]
	external = difft
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
